.superpowers/

# Wallpaper image library — large binaries, machine-local
wallpapers/

# Runtime state
quickshell/wallpaper-state.json
quickshell/lock-config.json
quickshell/ui-style.json
quickshell/hub-config.json
quickshell/launcher-usage.json
quickshell/launcher-config.json
quickshell/theme-config.json
quickshell/bar-config.json
quickshell/overview-config.json
quickshell/.qmlls.ini

# Matugen-regenerated theme files (rebuilt on every wallpaper change)
quickshell/theme/colors.json
tmux/colors.conf
yazi/theme.toml

# Plugin manager output
tmux/plugins/
yazi/plugins/

# Desktop mascot — licensed sprite ART is not redistributable (ignored);
# the license text itself IS tracked to preserve attribution.
quickshell/mascot/sprites/*
!quickshell/mascot/sprites/Aichan's Asset License.txt

# GTK: matugen-regenerated colors + mutable bookmarks (settings.ini is tracked)
gtk-3.0/gtk.css
gtk-4.0/gtk.css
gtk-3.0/bookmarks

{
  "app": "nvim",
  "id": "nvim",
  "binds": [
    { "key": "F", "mods": [], "combo": "Space f f", "category": "Find", "desc": "Find files (Telescope)" },
    { "key": "F", "mods": [], "combo": "Space f r", "category": "Find", "desc": "Recent files" },
    { "key": "F", "mods": [], "combo": "Space f s", "category": "Find", "desc": "Live grep in cwd" },
    { "key": "F", "mods": [], "combo": "Space f c", "category": "Find", "desc": "Grep word under cursor" },
    { "key": "E", "mods": [], "combo": "Space e e", "category": "Files", "desc": "File explorer (Neotree)" },
    { "key": "S", "mods": [], "combo": "Space S", "category": "Search", "desc": "Toggle Spectre (search/replace)" },
    { "key": "S", "mods": [], "combo": "Space s w", "category": "Search", "desc": "Search current word" },
    { "key": "S", "mods": [], "combo": "Space s p", "category": "Search", "desc": "Search in current file" },
    { "key": "C", "mods": [], "combo": "Space c a", "category": "LSP", "desc": "Code action" },
    { "key": "R", "mods": [], "combo": "Space r n", "category": "LSP", "desc": "Rename symbol" },
    { "key": "D", "mods": [], "combo": "Space d", "category": "LSP", "desc": "Open diagnostic float" },
    { "key": "Q", "mods": [], "combo": "Space q", "category": "LSP", "desc": "Diagnostics to loclist" },
    { "key": "D", "mods": [], "combo": "gd", "category": "LSP", "desc": "Go to definition" },
    { "key": "D", "mods": [], "combo": "gD", "category": "LSP", "desc": "Go to declaration" },
    { "key": "I", "mods": [], "combo": "gi", "category": "LSP", "desc": "Go to implementations" },
    { "key": "R", "mods": [], "combo": "gr", "category": "LSP", "desc": "Go to references" },
    { "key": "K", "mods": [], "combo": "K", "category": "LSP", "desc": "Hover documentation" },
    { "key": "T", "mods": [], "combo": "Space t v", "category": "Terminal", "desc": "Vertical terminal" },
    { "key": "T", "mods": [], "combo": "Space t f", "category": "Terminal", "desc": "Floating terminal" },
    { "key": "T", "mods": [], "combo": "Space t t", "category": "Terminal", "desc": "Tab terminal" },
    { "key": "G", "mods": [], "combo": "Space l g", "category": "Git", "desc": "Open LazyGit" },
    { "key": "D", "mods": [], "combo": "Space d f", "category": "Git", "desc": "Toggle Diffview" },
    { "key": "U", "mods": [], "combo": "Space u", "category": "Edit", "desc": "Toggle Undotree" },
    { "key": "M", "mods": [], "combo": "Space m d", "category": "Markdown", "desc": "Markdown preview" },
    { "key": "Y", "mods": [], "combo": "Space y", "category": "Edit", "desc": "Yank to system clipboard" },
    { "key": "W", "mods": [], "combo": "Space w", "category": "Window", "desc": "Window command prefix" },
    { "key": "J", "mods": [], "combo": "J", "category": "Edit", "desc": "Join line below" },
    { "key": "J", "mods": [], "combo": "v J", "category": "Edit", "desc": "Move selection down" },
    { "key": "K", "mods": [], "combo": "v K", "category": "Edit", "desc": "Move selection up" },
    { "key": "N", "mods": [], "combo": "n", "category": "Search", "desc": "Next match (centered)" },
    { "key": "N", "mods": [], "combo": "N", "category": "Search", "desc": "Previous match (centered)" },
    { "key": "D", "mods": ["CTRL"], "category": "Navigate", "desc": "Half-page down (centered)" },
    { "key": "U", "mods": ["CTRL"], "category": "Navigate", "desc": "Half-page up (centered)" }
  ]
}

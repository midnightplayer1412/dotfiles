{
  "app": "ghostty",
  "id": "ghostty",
  "binds": [
    { "key": "R", "mods": ["CTRL", "SHIFT"], "category": "App", "desc": "Reload config" },
    { "key": "H", "mods": ["CTRL", "SHIFT"], "category": "Split", "desc": "New split left" },
    { "key": "L", "mods": ["CTRL", "SHIFT"], "category": "Split", "desc": "New split right" },
    { "key": "K", "mods": ["CTRL", "SHIFT"], "category": "Split", "desc": "New split up" },
    { "key": "J", "mods": ["CTRL", "SHIFT"], "category": "Split", "desc": "New split down" },
    { "key": "H", "mods": ["ALT"], "category": "Split", "desc": "Focus split left" },
    { "key": "J", "mods": ["ALT"], "category": "Split", "desc": "Focus split down" },
    { "key": "K", "mods": ["ALT"], "category": "Split", "desc": "Focus split up" },
    { "key": "L", "mods": ["ALT"], "category": "Split", "desc": "Focus split right" },
    { "key": "RETURN", "mods": ["ALT"], "category": "Split", "desc": "Toggle split zoom" }
  ]
}
